{
  "name": "astrolab-case-studies",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:push": "npm -w packages/db run db:push",
    "db:generate": "npm -w packages/db run db:generate",
    "db:seed": "npm -w packages/db run db:seed"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.7"
  },
  "packageManager": "npm@11.10.1",
  "engines": {
    "node": ">=20"
  }
}
